---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header class="border-b border-stone-300/70 bg-[#f6f2ec]/90 px-4 backdrop-blur">
	<nav class="mx-auto flex max-w-5xl items-center justify-between gap-4 py-5">
		<a href="/" class="min-w-0 truncate text-base font-bold text-stone-800 no-underline">
			{SITE_TITLE}
		</a>

		<div class="flex shrink-0 items-center gap-1">
			<HeaderLink href="/">首页</HeaderLink>
			<HeaderLink href="/blog">文章</HeaderLink>
			<HeaderLink href="/about">关于</HeaderLink>
		</div>
	</nav>
</header>
