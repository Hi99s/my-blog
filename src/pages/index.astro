---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main class="page-shell py-16 sm:py-24">
			<section class="max-w-3xl">
				<p class="text-sm text-stone-500">技术 / 阅读 / 生活</p>
				<h1 class="mt-5 text-4xl font-bold leading-tight text-stone-800 sm:text-5xl">
					你好，我是 hi99s。
				</h1>
				<p class="mt-6 text-lg leading-8 text-stone-600">
					这里是我的博客。写前端工程，也写一些读书、观察和日常里值得留下的片段。
				</p>
				<div class="mt-10 flex flex-wrap gap-3">
					<a class="border border-stone-400 px-5 py-3 text-sm font-bold text-stone-800 no-underline transition hover:bg-stone-800 hover:text-[#f6f2ec]" href="/blog">
						查看文章
					</a>
					<a class="px-5 py-3 text-sm font-bold text-stone-600 no-underline transition hover:text-stone-950" href="/about">
						关于我
					</a>
				</div>
			</section>

			<section class="mt-20 grid gap-6 border-t border-stone-300 pt-10 sm:grid-cols-3">
				<div>
					<p class="text-sm text-stone-500">其一</p>
					<h2 class="mt-2 text-xl font-bold text-stone-800">工程记录</h2>
					<p class="mt-3 text-sm leading-6 text-stone-600">整理项目实践、工具链和问题复盘。</p>
				</div>
				<div>
					<p class="text-sm text-stone-500">其二</p>
					<h2 class="mt-2 text-xl font-bold text-stone-800">阅读摘记</h2>
					<p class="mt-3 text-sm leading-6 text-stone-600">保留读到的句子、想法和延伸思考。</p>
				</div>
				<div>
					<p class="text-sm text-stone-500">其三</p>
					<h2 class="mt-2 text-xl font-bold text-stone-800">生活切片</h2>
					<p class="mt-3 text-sm leading-6 text-stone-600">记录一些安静、具体、真实的时刻。</p>
				</div>
			</section>
		</main>
	</body>
</html>
